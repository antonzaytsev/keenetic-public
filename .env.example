# Router connection
KEENETIC_HOST=192.168.1.1
KEENETIC_LOGIN=admin
KEENETIC_PASSWORD=your_password

# Backend
RACK_ENV=development
BACKEND_PORT=4000

# Frontend
FRONTEND_PORT=3000

# Scheduler — router config backup
# Backups are stored in BACKUP_CONFIG_DIR (host path), mounted into the container.
# Up to BACKUP_CONFIG_KEEP files are kept; older ones are deleted automatically.
BACKUP_CONFIG_DIR=./scheduler/backups
BACKUP_CONFIG_TIME=02:00
BACKUP_CONFIG_RUN_ON_START=true
BACKUP_CONFIG_KEEP=10
